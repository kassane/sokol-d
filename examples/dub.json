		{
			"name": "blend",
			"sourceFiles": [
				"blend.d",
				"shaders/blend.d"
			],
			"targetPath": "build",
			"targetType": "executable",
			"dependencies": {
				"sokol-d": {
					"path": ".."
				}
			},
			"configurations": [
				{
					"name": "native",
					"subConfigurations": {
						"sokol-d": "sokol-static"
					}
				},
				{
					"name": "wasm",
					"targetType": "staticLibrary",
					"postBuildCommands-posix": [
						"${SOKOL_D_PACKAGE_DIR}/vendor/emsdk/upstream/emscripten/emcc -o build/blend.html -L${SOKOL_D_PACKAGE_DIR}/build -Lbuild/ -lsokol -lblend -sUSE_WEBGL2=1 -sNO_FILESYSTEM=1 -sMALLOC=emmalloc --closure 1 -sSTACK_SIZE=512KB -sASSERTIONS=0 --shell-file=${SOKOL_D_PACKAGE_DIR}/src/sokol/web/shell.html",
						"rm build/*.a"
					],
					"postBuildCommands-windows": [
						"${SOKOL_D_PACKAGE_DIR}\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -o build\\blend.html -L..\\build -Lbuild -lsokol -lblend -sUSE_WEBGL2=1 -sNO_FILESYSTEM=1 -sMALLOC=emmalloc --closure 1 -sSTACK_SIZE=512KB -sASSERTIONS=0 --shell-file=${SOKOL_D_PACKAGE_DIR}\\src\\sokol\\web\\shell.html",
						"del build\\*.a"
					],
