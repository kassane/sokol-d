	"license": "Zlib",
	"authors": [
		"Matheus França",
		"Andre Weissflog"
	],
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo"
			]
		},
		"release": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"release-betterc": {
			"buildOptions": [
				"betterC",
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		}
	},
	"subPackages": [
		{
			"name": "blend",
			"sourceFiles": [
				"blend.d",
				"shaders/blend.d"
			],
			"targetPath": "build",
			"targetType": "executable",
			"dependencies": {
				"sokol-d": {
					"path": ".."
				}
			},
			"configurations": [
				{
					"name": "native",
					"subConfigurations": {
						"sokol-d": "sokol-static"
					}
				},
				{
					"name": "wasm",
					"targetName": "blend.html",
					"subConfigurations": {
						"sokol-d": "sokol-wgles3"
					}
				},
				{
					"name": "wgpu",
					"targetName": "blend.html",
