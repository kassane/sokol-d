	"description": "D bindings for sokol",
	"license": "Zlib",
	"name": "sokol-d",
	"version": "0.2.1",
	"toolchainRequirements": {
		"frontend": ">=2.105.0"
	},
	"configurations": [
		{
			"name": "sokol",
			"sourcePaths": [
				"src/sokol"
			],
			"targetPath": "build",
			"preBuildCommands-linux": [
				"mkdir -p $PACKAGE_DIR/build",
				"$DC -run $PACKAGE_DIR/build.d --download-zig",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"$PACKAGE_DIR/vendor/zig/zig cc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
