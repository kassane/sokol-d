				"$PACKAGE_DIR/vendor/zig/zig.exe cc -target native-native-msvc -DNDEBUG -DIMPL -DSOKOL_D3D11 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.obj $PACKAGE_DIR/src/sokol/c/sokol_app.c",
