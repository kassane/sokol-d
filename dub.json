				"$PACKAGE_DIR/vendor/zig/zig.exe ar rcs $PACKAGE_DIR/build/sokol.lib $PACKAGE_DIR/build/*.obj",
				"rm $PACKAGE_DIR/build/*.obj"
			]
		},
		{
