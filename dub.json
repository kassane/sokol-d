{
	"authors": [
		"Matheus Catarino França",
		"Andre Weissflog"
	],
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo"
			]
		},
		"release": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"optimize"
			]
		},
		"release-debug": {
			"buildOptions": [
				"releaseMode",
				"debugInfo",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"unittest": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"unittests"
			]
		}
	},
	"description": "D bindings for sokol",
	"license": "Zlib",
	"name": "sokol-d",
	"version": "0.2.1",
	"toolchainRequirements": {
		"frontend": ">=2.105.0"
	},
	"configurations": [
		{
			"name": "sokol",
			"sourcePaths": [
				"src/sokol"
			],
			"targetPath": "build",
			"preBuildCommands-linux": [
				"mkdir -p $PACKAGE_DIR/build",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"ar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-osx": [
				"mkdir -p $PACKAGE_DIR/build",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"ar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"powershell -Command \"mkdir -Force $PACKAGE_DIR\\build\"",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_log.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_log.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_app.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_app.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_gfx.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_gfx.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_time.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_time.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_audio.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_audio.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_gl.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_gl.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_debugtext.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_debugtext.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_shape.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_shape.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_glue.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_glue.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_fetch.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_fetch.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /W0 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_memtrack.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_memtrack.c",
				"lib.exe /nologo /OUT:$PACKAGE_DIR\\build\\sokol.lib $PACKAGE_DIR\\build\\*.obj",
				"powershell -Command Remove-Item $PACKAGE_DIR\\build\\*.obj"
			]
		},
		{
			"name": "genshaders",
			"targetType": "none",
			"preGenerateCommands": [
				"$DC -run $PACKAGE_DIR/build.d --download-sokol-tools"
			]
		},
		{
			"name": "emscripten",
			"dflags-ldc": [
				"-mtriple=wasm32-unknown-emscripten"
			],
			"targetPath": "build",
			"preBuildCommands-posix": [
				"mkdir -p $PACKAGE_DIR/build",
				"$DC -run $PACKAGE_DIR/build.d --download-emsdk",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"powershell -Command \"mkdir -Force $PACKAGE_DIR\\build\"",
				"$DC -run $PACKAGE_DIR/build.d --download-emsdk",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_log.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_log.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_app.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_app.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_gfx.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_gfx.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_time.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_time.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_audio.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_audio.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_gl.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_gl.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_debugtext.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_debugtext.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_shape.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_shape.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_glue.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_glue.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_fetch.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_fetch.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emcc.bat -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR\\build\\sokol_memtrack.o $PACKAGE_DIR\\src\\sokol\\c\\sokol_memtrack.c",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emar.bat rcs $PACKAGE_DIR\\build\\libsokol.a $PACKAGE_DIR\\build\\*.o",
				"powershell -Command Remove-Item $PACKAGE_DIR\\build\\*.obj"
			]
		}
	]
}