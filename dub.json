{
	"authors": [
		"Matheus Catarino França",
		"Andre Weissflog"
	],
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo"
			]
		},
		"release": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"optimize"
			]
		},
		"release-debug": {
			"buildOptions": [
				"releaseMode",
				"debugInfo",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"release-betterc": {
			"buildOptions": [
				"betterC",
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"unittest": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"unittests"
			]
		}
	},
	"description": "D bindings for sokol",
	"license": "Zlib",
	"name": "sokol-d",
	"version": "0.2.1",
	"toolchainRequirements": {
		"ldc": ">=1.40.0"
	},
	"dflags": [
		"-preview=all"
	],
	"dflags-dmd": [
		"-verrors=context"
	],
	"dflags-ldc": [
		"--verrors-context"
	],
	"lflags-posix": [
		"-L$PACKAGE_DIR/build"
	],
	"lflags-windows": [
		"/LIBPATH:$PACKAGE_DIR\\build"
	],
	"configurations": [
		{
			"name": "sokol-static",
			"sourcePaths": [
				"src/sokol"
			],
			"excludedSourceFiles": [
				"src/sokol/imgui.d"
			],
			"dflags": [
				"-i=sokol",
				"-i=shaders",
				"-i=handmade"
			],
			"dflags-ldc": [
				"-mcpu=native"
			],
			"targetName": "sokold",
			"targetPath": "build",
			"libs": [
				"sokol"
			],
			"lflags-osx": [
				"-framework",
				"Cocoa",
				"-framework",
				"QuartzCore",
				"-framework",
				"Foundation",
				"-framework",
				"MetalKit",
				"-framework",
				"Metal",
				"-framework",
				"AudioToolbox"
			],
			"libs-linux": [
				"X11",
				"GL",
				"Xi",
				"Xcursor",
				"asound"
			],
			"libs-windows": [
				"dxgi",
				"d3d11"
			],
			"preBuildCommands-linux": [
				"mkdir -p $PACKAGE_DIR/build",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -DSOKOL_DISABLE_WAYLAND -Wall -Wextra -Wno-unused-function -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"ar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-osx": [
				"mkdir -p $PACKAGE_DIR/build",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -Wextra -Wno-unused-function -Wno-return-type-c-linkage -ObjC -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -Wextra -Wno-unused-function -Wno-return-type-c-linkage -ObjC -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -Wextra -Wno-unused-function -Wno-return-type-c-linkage -ObjC -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -Wextra -Wno-unused-function -Wno-return-type-c-linkage -ObjC -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
