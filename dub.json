				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emcc -DNDEBUG -DIMPL -DSOKOL_GLES3 -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
