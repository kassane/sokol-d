{
	"authors": [
		"Matheus Catarino França",
		"Andre Weissflog"
	],
	"buildTypes": {
		"debug": {
			"buildOptions": [
				"debugMode",
				"debugInfo"
			]
		},
		"release": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"optimize"
			]
		},
		"release-debug": {
			"buildOptions": [
				"releaseMode",
				"debugInfo",
				"inline",
				"optimize"
			]
		},
		"release-nobounds": {
			"buildOptions": [
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"release-betterc": {
			"buildOptions": [
				"betterC",
				"releaseMode",
				"inline",
				"noBoundsCheck",
				"optimize"
			]
		},
		"unittest": {
			"buildOptions": [
				"debugMode",
				"debugInfo",
				"unittests"
			]
		}
	},
	"description": "D bindings for sokol",
	"license": "Zlib",
	"name": "sokol-d",
	"version": "0.2.1",
	"toolchainRequirements": {
		"ldc": ">=1.40.0"
	},
	"configurations": [
		{
			"name": "sokol",
			"sourcePaths": [
				"src/sokol"
			],
			"dflags-ldc": [
				"-mcpu=native"
			],
			"targetName": "sokold",
			"targetPath": "build",
			"preBuildCommands-linux": [
				"mkdir -p $PACKAGE_DIR/build",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"gcc -DNDEBUG -DIMPL -DSOKOL_GLCORE -Wall -Wno-return-type-c-linkage -Wno-unused-function -O3 -fPIE -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"ar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-osx": [
				"mkdir -p $PACKAGE_DIR/build",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_log.o $PACKAGE_DIR/src/sokol/c/sokol_log.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_app.o $PACKAGE_DIR/src/sokol/c/sokol_app.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_gfx.o $PACKAGE_DIR/src/sokol/c/sokol_gfx.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_time.o $PACKAGE_DIR/src/sokol/c/sokol_time.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_audio.o $PACKAGE_DIR/src/sokol/c/sokol_audio.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_gl.o $PACKAGE_DIR/src/sokol/c/sokol_gl.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_debugtext.o $PACKAGE_DIR/src/sokol/c/sokol_debugtext.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_glue.o $PACKAGE_DIR/src/sokol/c/sokol_glue.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_fetch.o $PACKAGE_DIR/src/sokol/c/sokol_fetch.c",
				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -ObjC -O3 -fPIE -framework Foundation -framework MetalKit -framework Metal -c -o $PACKAGE_DIR/build/sokol_memtrack.o $PACKAGE_DIR/src/sokol/c/sokol_memtrack.c",
				"ar rcs $PACKAGE_DIR/build/libsokol.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"powershell -Command \"mkdir -Force $PACKAGE_DIR\\build\"",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_log.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_log.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_app.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_app.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_gfx.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_gfx.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_time.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_time.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_audio.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_audio.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_gl.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_gl.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_debugtext.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_debugtext.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_shape.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_shape.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_glue.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_glue.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_fetch.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_fetch.c",
				"cl.exe /DNDEBUG /DIMPL /DSOKOL_D3D11 /nologo /wd4190 /O2 /c /Fo$PACKAGE_DIR\\build\\sokol_memtrack.obj $PACKAGE_DIR\\src\\sokol\\c\\sokol_memtrack.c",
				"lib.exe /nologo /OUT:$PACKAGE_DIR\\build\\sokol.lib $PACKAGE_DIR\\build\\*.obj",
				"powershell -Command Remove-Item $PACKAGE_DIR\\build\\*.obj"
			]
		},
		{
			"name": "imgui",
			"sourcePaths": [
				"src/imgui"
			],
			"excludedSourceFiles": [
				"src/sokol/*.d",
				"src/handmade/*.d"
			],
			"targetName": "cimguid",
			"targetPath": "build",
			"dflags-ldc": [
				"-P-I$PACKAGE_DIR/vendor/cimgui",
				"-mcpu=native"
			],
			"preBuildCommands-linux": [
				"mkdir -p $PACKAGE_DIR/build",
				"$DC -run $PACKAGE_DIR/build.d --download-imgui",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui.cpp",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_demo.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_demo.cpp",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_draw.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_draw.cpp",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_tables.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_tables.cpp",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_widgets.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_widgets.cpp",
				"g++ -Wall -Wno-return-type-c-linkage -Wno-unused-function -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/cimgui.o $PACKAGE_DIR/vendor/cimgui/cimgui.cpp",
				"ar rcs $PACKAGE_DIR/build/libcimgui.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-osx": [
				"mkdir -p $PACKAGE_DIR/build",
				"$DC -run $PACKAGE_DIR/build.d --download-imgui",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui.cpp",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_demo.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_demo.cpp",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_draw.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_draw.cpp",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_tables.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_tables.cpp",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_widgets.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_widgets.cpp",
				"clang++ -std=c++14 -Wall -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/cimgui.o $PACKAGE_DIR/vendor/cimgui/cimgui.cpp",
				"ar rcs $PACKAGE_DIR/build/libcimgui.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"powershell -Command \"mkdir -Force $PACKAGE_DIR\\build\"",
				"$DC -run $PACKAGE_DIR/build.d --download-imgui",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\imgui.obj $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui.cpp",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\imgui_demo.obj $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_demo.cpp",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\imgui_draw.obj $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_draw.cpp",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\imgui_tables.obj $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_tables.cpp",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\imgui_widgets.obj $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_widgets.cpp",
				"cl.exe /DNDEBUG /O2 /nologo /c /Fo$PACKAGE_DIR\\build\\cimgui.obj $PACKAGE_DIR\\vendor\\cimgui\\cimgui.cpp",
				"lib.exe /nologo /OUT:$PACKAGE_DIR\\build\\cimgui.lib $PACKAGE_DIR\\build\\*.obj",
				"powershell -Command \"Remove-Item $PACKAGE_DIR\\build\\*.obj\""
			]
		},
		{
			"name": "imgui-wasm",
			"sourcePaths": [
				"src/imgui"
			],
			"excludedSourceFiles": [
				"src/sokol/*.d",
				"src/handmade/*.d"
			],
			"targetName": "cimguid",
			"targetPath": "build",
			"dflags-ldc": [
				"-P-I$PACKAGE_DIR/vendor/cimgui",
				"-mcpu=wasm32-unknown-emscripten"
			],
			"preBuildCommands-posix": [
				"mkdir -p $PACKAGE_DIR/build",
				"$DC -run $PACKAGE_DIR/build.d --download-emsdk --download-imgui",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_demo.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_demo.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_draw.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_draw.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_tables.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_tables.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/imgui_widgets.o $PACKAGE_DIR/vendor/cimgui/imgui/imgui_widgets.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emc++ -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR/build/cimgui.o $PACKAGE_DIR/vendor/cimgui/cimgui.cpp",
				"$PACKAGE_DIR/vendor/emsdk/upstream/emscripten/emar rcs $PACKAGE_DIR/build/libcimgui.a $PACKAGE_DIR/build/*.o",
				"rm $PACKAGE_DIR/build/*.o"
			],
			"preBuildCommands-windows": [
				"powershell -Command \"mkdir -Force $PACKAGE_DIR\\build\"",
				"$DC -run $PACKAGE_DIR\\build.d --download-emsdk --download-imgui",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\imgui.o $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\imgui_demo.o $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_demo.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\imgui_draw.o $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_draw.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\imgui_tables.o $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_tables.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\imgui_widgets.o $PACKAGE_DIR\\vendor\\cimgui\\imgui\\imgui_widgets.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emc++.bat -DNDEBUG -O3 -fPIE -c -o $PACKAGE_DIR\\build\\cimgui.o $PACKAGE_DIR\\vendor\\cimgui\\cimgui.cpp",
				"$PACKAGE_DIR\\vendor\\emsdk\\upstream\\emscripten\\emar.bat rcs $PACKAGE_DIR\\build\\libcimgui.a $PACKAGE_DIR\\build\\*.o",
				"powershell -Command \"Remove-Item $PACKAGE_DIR\\build\\*.obj\""
			]
		},
		{
			"name": "emscripten",
			"dflags-ldc": [
				"-mtriple=wasm32-unknown-emscripten"
			],
			"targetName": "sokold",
			"targetPath": "build",
