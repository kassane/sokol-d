				"clang -DNDEBUG -DIMPL -DSOKOL_METAL -Wall -Wextra -Wno-unused-function -Wno-return-type-c-linkage -ObjC -O2 -fPIE -c -o $PACKAGE_DIR/build/sokol_shape.o $PACKAGE_DIR/src/sokol/c/sokol_shape.c",
